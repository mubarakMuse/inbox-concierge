# Copy to .env and fill in values
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:5001/api/auth/callback
OPENAI_API_KEY=
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Postgres (local Docker or RDS)
DATABASE_URL=postgres://postgres:postgres@localhost:5434/inbox_concierge
DATABASE_SSL=false

# Optional: secret for signing user-id cookie (set in production)
COOKIE_SECRET=

# Optional: encrypt OAuth tokens at rest (32-byte hex or any passphrase)
TOKEN_ENCRYPTION_KEY=

# Queue: local (dev default) runs jobs in-process; sqs uses AWS SQS + Lambda
QUEUE_DRIVER=local
SQS_QUEUE_URL=
AWS_REGION=us-east-1
