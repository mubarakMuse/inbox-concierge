# Copy to .env and fill in values
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:5001/api/auth/callback
OPENAI_API_KEY=
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Postgres (default storage)
STORAGE_DRIVER=pg
DATABASE_URL=postgres://postgres:postgres@localhost:5434/inbox_concierge
DATABASE_SSL=false

# Optional legacy Supabase storage
# STORAGE_DRIVER=supabase
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: secret for signing user-id cookie (set in production)
COOKIE_SECRET=

# Queue: local (dev default) runs jobs in-process; sqs uses AWS SQS + Lambda
QUEUE_DRIVER=local
SQS_QUEUE_URL=
AWS_REGION=us-east-1
